generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id            String    @id @default(uuid())
  nom           String
  prenom        String
  email         String    @unique
  motDePasse    String
  telephone     String?
  dateNaissance DateTime?
  cni           String?   @unique
  cniRecto      String?
  cniVerso      String?
  demandes      Demande[]
  createdAt     DateTime  @default(now())
}

model AdminMairie {
  id         String   @id @default(uuid())
  nom        String
  prenom     String
  codeUnique String   @unique
  motDePasse String
  role       String   @default("gestionnaire")
  createdAt  DateTime @default(now())
}

model Demande {
  id                    String    @id @default(uuid())
  utilisateurId         String
  utilisateur           Utilisateur @relation(fields: [utilisateurId], references: [id])
  typeActe              String
  statut                String    @default("EN_ATTENTE") // EN_ATTENTE, ACCEPTE, REJETE
  etapeConfirmation     String    @default("EN_ATTENTE") // EN_ATTENTE, EMAIL_ENVOYE, CONFIRME, MODIFICATIONS_DEMANDEES, RENDEZ_VOUS_FIXE
  donnees               Json
  codeUnique            String    @unique
  raisonRejet           String?
  verificationIA        Json?
  documents             Document[]
  rendezVous            RendezVous?
  codeRecuperation      String?   @unique
  dateConfirmation      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model RendezVous {
  id              String    @id @default(uuid())
  demandeId       String    @unique
  demande         Demande   @relation(fields: [demandeId], references: [id])
  dateRendezVous  DateTime
  codeRecuperation String  @unique
  statut          String    @default("FIXE") // FIXE, EFFECTUE, ANNULE
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Document {
  id        String  @id @default(uuid())
  demandeId String
  demande   Demande @relation(fields: [demandeId], references: [id])
  nom       String
  url       String
  type      String
}
